name: "SafeDriver: Ingestão Bronze RFB"

on:
  workflow_dispatch:

jobs:
  build-bronze:
    runs-on: ubuntu-latest
    
    env:
      # Mapeamos as secrets do R2 para as variáveis padrão do AWS CLI
      AWS_ACCESS_KEY_ID: ${{ secrets.R2_ACCESS_KEY_ID }}
      AWS_SECRET_ACCESS_KEY: ${{ secrets.R2_SECRET_ACCESS_KEY }}
      AWS_DEFAULT_REGION: "auto"
      R2_ENDPOINT_URL: ${{ secrets.R2_ENDPOINT_URL }}
      R2_BUCKET_NAME: ${{ secrets.R2_BUCKET_NAME }}
      
      # Segurança
      LGPD_PEPPER: ${{ secrets.LGPD_PEPPER }}
      LGPD_SALT: ${{ secrets.LGPD_SALT }}

    steps:
      - name: Checkout do Repositório
        uses: actions/checkout@v4

      - name: Configurar Ambiente Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      # Download direto da Receita Federal
      - name: Baixar Dados Oficiais (Snapshot)
        run: |
          echo "📥 Baixando base da Receita Federal..."
          wget https://arquivos.receitafederal.gov.br/dados/cnpj/dados_abertos_cnpj/2024-04/Estabelecimentos0.zip
          unzip Estabelecimentos0.zip
          mv *.ESTABELE* dados_rfb.csv

      - name: Instalar Dependências de Engenharia
        run: |
          pip install --upgrade pip
          pip install polars boto3 pyarrow requests

      - name: Executar Pipeline Ingestão Bronze
        run: |
          export PYTHONPATH=$PYTHONPATH:$(pwd)
          python autobot/bronze/malha_geo/ingestor_receita_federal.py

      - name: Notificar Falha no Discord
        if: failure()
        run: |
          curl -H "Content-Type: application/json" \
          -d '{"content": "🚨 **[SafeDriver] FALHA NA BRONZE:** A pipeline de ingestão falhou!"}' \
          ${{ secrets.DISCORD_ERRO }}

      - name: Notificar Sucesso no Discord
        if: success()
        run: |
          curl -H "Content-Type: application/json" \
          -d '{"content": "✅ **[SafeDriver] SUCESSO:** Camada Bronze atualizada com histórico oficial no R2."}' \
          ${{ secrets.DISCORD_SUCESSO }}
